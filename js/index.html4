<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>Telegram Confirm Light</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,typography,container-queries"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect"/>
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet"/>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#2AABEE",
                        "background-light": "#f0f2f5",
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    boxShadow: {
                        'glass': '0 8px 32px 0 rgba(31, 38, 135, 0.15)',
                        'glass-button': '0 4px 15px rgba(42, 171, 238, 0.35)',
                        'glow': '0 0 20px rgba(42, 171, 238, 0.5)',
                        'inner-light': 'inset 0 1px 0 rgba(255, 255, 255, 0.4)',
                        'sheet-top': '0 -10px 40px rgba(0,0,0,0.1)',
                    },
                    backdropBlur: {
                        'xs': '2px',
                        'xl': '24px',
                    },
                },
            },
        };
    </script>
    <style type="text/tailwindcss">
        @layer utilities {
            .glass-sheet {
                @apply bg-white/80 backdrop-blur-xl border-t border-white/50 shadow-sheet-top rounded-t-[2.5rem];
            }
            .glass-button-primary {
                @apply bg-primary text-white shadow-glass-button border-t border-white/20 relative overflow-hidden;
            }
            .glass-button-secondary {
                @apply bg-transparent hover:bg-white/40 text-slate-500 backdrop-blur-md transition-all;
            }
            .shine-overlay {
                background: linear-gradient(
                    to bottom,
                    rgba(255, 255, 255, 0.3) 0%,
                    rgba(255, 255, 255, 0) 100%
                );
            }
        }
    </style>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>
<body class="bg-background-light min-h-screen flex flex-col font-sans antialiased relative overflow-hidden">
    
    <!-- Фоновые декорации -->
    <div class="absolute inset-0 z-0">
        <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-blue-50 via-indigo-50 to-purple-50 opacity-100"></div>
        <div class="absolute top-10 left-10 w-96 h-96 bg-blue-300 rounded-full mix-blend-multiply filter blur-[80px] opacity-30"></div>
        <div class="absolute top-40 right-10 w-96 h-96 bg-purple-300 rounded-full mix-blend-multiply filter blur-[80px] opacity-30"></div>
        <div class="absolute -bottom-20 left-1/2 transform -translate-x-1/2 w-96 h-96 bg-pink-300 rounded-full mix-blend-multiply filter blur-[80px] opacity-30"></div>
        <div class="w-full h-full flex flex-col p-4 opacity-40 blur-[2px] pointer-events-none select-none">
            <div class="h-14 w-full bg-white rounded-2xl mb-6 shadow-sm"></div>
            <div class="flex gap-4 mb-6">
                <div class="h-40 w-1/2 bg-white rounded-2xl shadow-sm"></div>
                <div class="h-40 w-1/2 bg-white rounded-2xl shadow-sm"></div>
            </div>
            <div class="h-72 w-full bg-white rounded-2xl mb-6 shadow-sm"></div>
            <div class="h-24 w-full bg-white rounded-2xl shadow-sm"></div>
        </div>
    </div>

    <!-- Затемнение фона -->
    <div class="fixed inset-0 bg-black/20 backdrop-blur-[4px] z-20"></div>

    <!-- Модальное окно (Sheet) -->
    <div class="fixed inset-x-0 bottom-0 z-30 flex items-end justify-center w-full">
        <div class="glass-sheet w-full max-w-lg mx-auto pb-10 pt-4 px-6 flex flex-col items-center relative transform transition-transform duration-500 translate-y-0">
            <div class="w-12 h-1.5 bg-gray-300/80 rounded-full mb-8 mx-auto"></div>
            
            <div class="flex flex-col items-center text-center w-full max-w-sm mx-auto">
                <!-- Обновленный логотип Telegram (SVG пользователя) -->
                <div class="relative w-24 h-24 mb-6 flex items-center justify-center">
                    <div class="absolute inset-0 bg-primary rounded-full blur-2xl opacity-40"></div>
                    <svg class="relative w-20 h-20 shadow-xl shadow-blue-500/30 rounded-full" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 240.1 240.1">
                        <linearGradient id="Oval_1_" gradientUnits="userSpaceOnUse" x1="-838.041" y1="660.581" x2="-838.041" y2="660.3427" gradientTransform="matrix(1000 0 0 -1000 838161 660581)"> 
                            <stop offset="0" style="stop-color:#2AABEE"/> 
                            <stop offset="1" style="stop-color:#229ED9"/>
                        </linearGradient>
                        <circle fill-rule="evenodd" clip-rule="evenodd" fill="url(#Oval_1_)" cx="120.1" cy="120.1" r="120.1"/>
                        <path fill-rule="evenodd" clip-rule="evenodd" fill="#FFFFFF" d="M54.3,118.8c35-15.2,58.3-25.3,70-30.2 c33.3-13.9,40.3-16.3,44.8-16.4c1,0,3.2,0.2,4.7,1.4c1.2,1,1.5,2.3,1.7,3.3s0.4,3.1,0.2,4.7c-1.8,19-9.6,65.1-13.6,86.3 c-1.7,9-5,12-8.2,12.3c-7,0.6-12.3-4.6-19-9c-10.6-6.9-16.5-11.2-26.8-18c-11.9-7.8-4.2-12.1,2.6-19.1c1.8-1.8,32.5-29.8,33.1-32.3 c0.1-0.3,0.1-1.5-0.6-2.1c-0.7-0.6-1.7-0.4-2.5-0.2c-1.1,0.2-17.9,11.4-50.6,33.5c-4.8,3.3-9.1,4.9-13,4.8 c-4.3-0.1-12.5-2.4-18.7-4.4c-7.5-2.4-13.5-3.7-13-7.9C45.7,123.3,48.7,121.1,54.3,118.8z"/>
                    </svg>
                </div>
                
                <h2 class="text-2xl font-bold text-gray-900 mb-3 tracking-tight">
                    Вы хотите продолжить?
                </h2>
                
                <p class="text-base text-gray-500 mb-10 leading-relaxed font-medium px-4">
                    Вы будете перенаправлены во внешнее приложение Telegram.
                </p>
                
                <div class="w-full space-y-4 mb-safe">
                    <button class="w-full h-14 rounded-2xl glass-button-primary font-bold text-[17px] tracking-wide shadow-glow active:scale-[0.98] flex items-center justify-center group">
                        <span class="shine-overlay absolute inset-0 pointer-events-none"></span>
                        <span class="relative z-10 flex items-center gap-2">
                            <span>Продолжить</span>
                            <i class="fa-solid fa-arrow-right text-sm opacity-80 group-hover:translate-x-1 transition-transform"></i>
                        </span>
                    </button>
                    <button class="w-full h-12 rounded-2xl glass-button-secondary font-semibold text-[17px] tracking-wide active:opacity-70">
                        Отмена
                    </button>
                </div>
            </div>
            <div class="h-6 w-full"></div>
        </div>
    </div>

</body>
</html>